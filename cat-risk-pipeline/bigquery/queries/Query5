-- bigquery/queries/pipeline_health.sql
-- How many events landed in last 15 mins?
-- If 0 → pipeline might be broken!
SELECT
  COUNT(*)                      AS events_last_15_mins,
  MIN(timestamp)                AS earliest_event,
  MAX(timestamp)                AS latest_event,
  MAX(processed_at)             AS last_processed,
  TIMESTAMP_DIFF(
    CURRENT_TIMESTAMP(),
    MAX(PARSE_TIMESTAMP('%Y-%m-%dT%H:%M:%S', processed_at)),
    MINUTE
  )                             AS mins_since_last_event
FROM
  `cat-risk-pipeline-2026.cat_risk.events`
WHERE
  processed_at >= TIMESTAMP_SUB(CURRENT_TIMESTAMP(), INTERVAL 15 MINUTE);