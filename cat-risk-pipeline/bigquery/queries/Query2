-- bigquery/queries/event_trends.sql
SELECT
  DATE(timestamp)               AS event_date,
  event_type,
  COUNT(*)                      AS event_count,
  ROUND(AVG(risk_score), 2)     AS avg_risk_score
FROM
  `cat-risk-pipeline-2026.cat_risk.events`
WHERE
  timestamp >= TIMESTAMP_SUB(CURRENT_TIMESTAMP(), INTERVAL 7 DAY)
GROUP BY
  event_date,
  event_type
ORDER BY
  event_date DESC,
  event_count DESC;